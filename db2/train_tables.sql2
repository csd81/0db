-- Quick sanity checks.
select * from dbo.TrainingCompanies;
select * from dbo.Skills;
select * from dbo.EmploymentCategories;
select * from dbo.CategoryRequiredSkills;
select * from dbo.TrainingSessions;
select * from dbo.TrainingSessionSkills;
select * from dbo.TrainingParticipants;
select * from dbo.TrainingExamResults;
select * from dbo.CompanyYearFees;
go
